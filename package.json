{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@marimo-team/codemirror-sql",
  "version": "0.2.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "CodeMirror plugin for SQL",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marimo-team/codemirror-sql.git"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix",
    "test": "vitest",
    "demo": "vite build",
    "build": "tsc",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build",
    "release": "pnpm version",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "keywords": [
    "codemirror",
    "codemirror-plugin",
    "sql"
  ],
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.4.0",
  "peerDependencies": {
    "@codemirror/autocomplete": "^6",
    "@codemirror/lint": "^6",
    "@codemirror/state": "^6",
    "@codemirror/view": "^6"
  },
  "devDependencies": {
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/view": "6.43.0",
    "@testing-library/dom": "10.4.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "codemirror": "6.0.2",
    "jsdom": "29.1.1",
    "oxlint": "1.64.0",
    "playwright": "1.60.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "files": [
    "dist",
    "src/data/*.json"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dialects": {
      "import": {
        "types": "./dist/dialects/index.d.ts",
        "default": "./dist/dialects/index.js"
      }
    },
    "./data/common-keywords.json": "./src/data/common-keywords.json",
    "./data/duckdb-keywords.json": "./src/data/duckdb-keywords.json"
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": "*"
  },
  "module": "./dist/index.js",
  "dependencies": {
    "node-sql-parser": "^5.3.13"
  }
}
